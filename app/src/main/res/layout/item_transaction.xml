<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/hiva_card"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/textTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/hiva_red"
            android:textSize="15sp"
            android:textStyle="bold"
            tools:text="فروش - ۱ واحد" />

        <TextView
            android:id="@+id/textAmountIn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/hiva_text_secondary"
            android:textSize="13sp"
            tools:text="مبلغ ورودی: ۷۹,۵۷۷" />

        <TextView
            android:id="@+id/textMetric"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/hiva_text_secondary"
            android:textSize="13sp"
            tools:text="معیار: ۲۳,۰۰۰" />

        <TextView
            android:id="@+id/textAmountOut"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/hiva_text_secondary"
            android:textSize="13sp"
            tools:text="مبلغ خروجی: ۷۹,۵۷۳" />

        <TextView
            android:id="@+id/textPnl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="13sp"
            tools:text="سود/ضرر: ۹۲,۰۰۰ تومان"
            tools:textColor="@color/hiva_green" />

        <TextView
            android:id="@+id/textOpenedAt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/hiva_text_secondary"
            android:textSize="13sp"
            tools:text="زمان باز شدن: ۱۴۰۵/۰۱/۱۹ ۲۰:۲۵" />

        <TextView
            android:id="@+id/textClosedAt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/hiva_text_secondary"
            android:textSize="13sp"
            tools:text="زمان بسته شدن: ۱۴۰۵/۰۱/۱۹ ۲۰:۲۸" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
