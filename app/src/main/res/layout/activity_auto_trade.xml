<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/hiva_bg"
    android:fillViewport="true"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textAutoTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/auto_trade_title"
            android:textColor="@color/hiva_text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/bot_strategy_profile"
            android:textColor="@color/hiva_text_secondary"
            android:textSize="13sp" />

        <Spinner
            android:id="@+id/spinnerAutoStrategy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@color/hiva_card"
            android:padding="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/auto_trade_units"
            android:textColor="@color/hiva_text_secondary"
            android:textSize="13sp" />

        <Spinner
            android:id="@+id/spinnerAutoUnits"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@color/hiva_card"
            android:padding="8dp" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchAutoTestMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/auto_trade_test_mode"
            android:textColor="@color/hiva_text_primary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonStartTrade"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/auto_trade_start" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonStopTrade"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/auto_trade_stop"
                android:textColor="@color/hiva_text_primary" />
        </LinearLayout>

        <TextView
            android:id="@+id/textAutoTop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@color/hiva_card"
            android:padding="12dp"
            android:textColor="@color/hiva_text_primary"
            android:textSize="14sp"
            android:typeface="monospace" />

        <TextView
            android:id="@+id/textAutoSession"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@color/hiva_card"
            android:padding="12dp"
            android:textColor="@color/hiva_text_primary"
            android:textSize="14sp"
            android:typeface="monospace" />

        <TextView
            android:id="@+id/textAutoBacktestDay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@color/hiva_card"
            android:padding="12dp"
            android:textColor="@color/hiva_text_primary"
            android:textSize="14sp"
            android:typeface="monospace" />

        <TextView
            android:id="@+id/textAutoBacktestSignals"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@color/hiva_card"
            android:padding="12dp"
            android:textColor="@color/hiva_text_primary"
            android:textSize="13sp"
            android:typeface="monospace" />

        <TextView
            android:id="@+id/textAutoSignal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@color/hiva_card"
            android:padding="12dp"
            android:textColor="@color/hiva_text_primary"
            android:textSize="14sp"
            android:typeface="monospace" />

        <TextView
            android:id="@+id/textAutoDecision"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@color/hiva_card"
            android:padding="12dp"
            android:textColor="@color/hiva_text_secondary"
            android:textSize="13sp"
            android:typeface="monospace" />
    </LinearLayout>
</ScrollView>
